modules = ["nodejs-20", "bash", "nix"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Run tests"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm test"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
AI_AUDIT_LOG_ENABLED = "true"
AI_CITATION_MODE = "true"
AI_COMPLEX_MODEL = "gpt-4o-mini"
AI_CONFIDENCE_SCORE = "false"
AI_CONVERSATION_MEMORY = "false"
AI_EMBEDDING_MODEL = "text-embedding-3-small"
AI_GUILD_RATE_LIMIT_RPM = "60"
AI_MAX_RETRIES = "3"
AI_RATE_LIMIT_RPM = "60"
AI_REINDEX_ON_STARTUP = "false"
AI_RETRY_BASE_DELAY_MS = "1000"
AI_SIMPLE_MODEL = "gemini-1.5-flash"
AI_USER_RATE_LIMIT_RPM = "10"
API_MAX_RETRIES = "3"
API_RETRY_BACKOFF_MS = "1000"
API_TIMEOUT_MS = "30000"
BASE_PATH = "/"
CACHE_EMBEDDING_MAX = "1000"
CACHE_EMBEDDING_TTL_MS = "3600000"
CACHE_ENABLED = "true"
CACHE_RESPONSE_MAX = "500"
CACHE_RESPONSE_TTL_MS = "600000"
INDEXER_CHUNK_MAX_CHARS = "1200"
INDEXER_CHUNK_MIN_CHARS = "50"
INDEXER_CHUNK_OVERLAP_CHARS = "100"
INDEXER_CHUNK_TARGET_CHARS = "800"
INDEXER_EMBED_CONCURRENCY = "5"
MESSAGE_MAX_REGENERATIONS = "2"
MESSAGE_MAX_WORDS = "150"
MESSAGE_MIN_WORDS = "100"
NODE_ENV = "production"
PORT = "3000"
QDRANT_COLLECTION = "umakraft"
RAG_MAX_CONTEXT_TOKENS = "6000"
RAG_MIN_CHUNKS = "3"
SEARCH_CACHE_TTL_MS = "600000"
SEARCH_CONFIDENCE_FALLBACK = "0.65"
SEARCH_MAX_RESULTS = "5"
SEARCH_PROVIDER_TIMEOUT_MS = "5000"
TOPIC_FILTER_AUDIT_LOG = "true"
TOPIC_FILTER_CONFIDENCE_THRESHOLD = "0.70"
UMA_MOE_API_BASE_URL = "https://uma.moe/api"
VDB_BACKUP_PATH = "/data/vdb_backup"
VDB_EMBEDDING_DIM = "1536"
VDB_INDEX_INTERVAL_HOURS = "6"
VDB_MIN_SCORE = "0.60"
VDB_QUERY_CACHE_TTL_MS = "600000"
VDB_TOP_K = "8"
DISCORD_CLIENT_ID = "1526549146788429894"
DISCORD_GUILD_ID = "1489093959044173935"

[[ports]]
localPort = 3000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["node", "Distribution/Discord/index.js"]
