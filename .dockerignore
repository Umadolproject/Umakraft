# .dockerignore — files excluded from the Docker build context

node_modules
npm-debug.log*

.git
.gitignore

# Local dev / editor files
.env
.env.*
.vscode
.idea
*.swp
*.swo

# Test output / coverage
coverage
.nyc_output

# OS noise
.DS_Store
Thumbs.db

# Railway / Nix config (not needed inside the image)
nixpacks.toml
railway.toml
railway/

# Agent memory
.agents/
.local/
